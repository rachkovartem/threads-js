{
  "name": "threads-kit",
  "version": "0.1.0",
  "description": "TypeScript SDK for the official Meta Threads API",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["threads", "meta", "api", "sdk", "social-media"],
  "type": "module",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
